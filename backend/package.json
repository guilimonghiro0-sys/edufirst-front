{
  "name": "edufirst-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "node --experimental-specifier-resolution=node dist/main.js",
    "start:dev": "ts-node-dev --transpile-only --respawn --ignore-watch node_modules src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev --name init",
    "prisma:seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.0.2",
    "@nestjs/passport": "^10.0.2",
    "@nestjs/platform-fastify": "^10.3.0",
    "@prisma/client": "^5.12.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.0",
    "fastify": "^4.27.0",
    "jsonwebtoken": "^9.0.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.1.13"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "prisma": "^5.12.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
